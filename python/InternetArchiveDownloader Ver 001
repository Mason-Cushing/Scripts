import os
import sys
import subprocess

# ---------- auto install ----------
def install(package):
    subprocess.check_call([sys.executable, "-m", "pip", "install", package])

try:
    import internetarchive
except ImportError:
    print("Installing internetarchive...")
    install("internetarchive")
    import internetarchive

try:
    from tqdm import tqdm
except ImportError:
    print("Installing tqdm...")
    install("tqdm")
    from tqdm import tqdm

# ---------- imports ----------
from internetarchive import get_item
import requests
from concurrent.futures import ThreadPoolExecutor

# GUI folder picker
import tkinter as tk
from tkinter import filedialog

# ---------- ask user for archive item ----------
item_id = input("Enter Internet Archive item ID (example: psp-cso-collection): ").strip()

# ---------- folder picker ----------
root = tk.Tk()
root.withdraw()

print("Select download folder...")
save_dir = filedialog.askdirectory(title="Choose Download Folder")

if not save_dir:
    print("No folder selected. Exiting.")
    sys.exit()

print(f"\nFiles will be saved to: {save_dir}\n")

# ---------- fetch file list ----------
print("Fetching file list from archive...")

item = get_item(item_id)
files = item.files

download_files = [
    f for f in files
    if not f["name"].endswith((".xml", ".sqlite", ".jpg", ".png", ".gif", ".txt"))
]

print(f"Found {len(download_files)} files.\n")

# ---------- download function ----------
def download_file(fileinfo):
    url = f"https://archive.org/download/{item_id}/{fileinfo['name']}"
    filepath = os.path.join(save_dir, fileinfo["name"])

    os.makedirs(os.path.dirname(filepath), exist_ok=True)

    r = requests.get(url, stream=True)
    total = int(r.headers.get("content-length", 0))

    with open(filepath, "wb") as f, tqdm(
        desc=fileinfo["name"],
        total=total,
        unit="B",
        unit_scale=True,
        unit_divisor=1024,
        leave=False
    ) as bar:

        for chunk in r.iter_content(chunk_size=1024 * 64):
            if chunk:
                f.write(chunk)
                bar.update(len(chunk))

# ---------- multithreaded downloads ----------
threads = 8
print(f"Starting downloads using {threads} threads...\n")

with ThreadPoolExecutor(max_workers=threads) as executor:
    executor.map(download_file, download_files)

print("\nAll downloads completed.")
